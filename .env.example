# ── AI Provider ──────────────────────────────────────────────────────────────
# The tool auto-detects your provider from which key is set.
# You only need to fill in ONE section below.

# Option 1: Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OpenAI
# OPENAI_API_KEY=sk-...

# Option 3: OpenAI-compatible (e.g. Groq, Together, local Ollama)
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Option 4: Claude CLI (no key needed — uses your logged-in Claude session)
# AI_PROVIDER=claude-cli

# ── Optional overrides ────────────────────────────────────────────────────────
# AI_PROVIDER=anthropic        # force a specific provider
# AI_MODEL=claude-sonnet-4-6   # override the model
# AI_TIMEOUT_MS=300000         # per-call timeout in ms (default: 5 min)
# FORCE_REBUILD=1              # re-run all AI stages even if cached
